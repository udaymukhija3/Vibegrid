# Backend (Go API)
# When DATABASE_URL is set, the API uses the durable, transaction-safe Postgres
# store and applies migrations on startup. When it is unset, it falls back to a
# non-durable in-memory store (handy for quick local runs and tests).
DATABASE_URL="postgres://USER:PASSWORD@localhost:5432/vibegrid?sslmode=disable"
# Listen address. If unset, the app binds :$PORT when a PaaS injects PORT
# (Render/Railway/Cloud Run/Koyeb), else :8081.
VIBEGRID_ADDR=":8081"
# Set "true" to apply DB migrations on startup. Use on single-instance hosts
# that lack a release/pre-deploy hook (e.g. Render's free plan). Leave unset on
# multi-instance hosts (Fly) and run the `vibegrid migrate` release step instead.
VIBEGRID_MIGRATE_ON_BOOT="false"
VIBEGRID_TIMEZONE="Asia/Kolkata"
# Comma-separated browser origins allowed to call the API. Defaults to localhost.
VIBEGRID_ALLOWED_ORIGINS="http://localhost:3000"
# Set to "true" in production (HTTPS) so the session cookie carries the Secure flag.
VIBEGRID_SECURE_COOKIES="false"
# Optional comma-separated terms/phrases blocked from public community puzzles.
VIBEGRID_BLOCKED_TERMS=""
# Browser admin login. Use a long random session secret in production.
VIBEGRID_ADMIN_PASSWORD=""
VIBEGRID_ADMIN_SESSION_SECRET=""
# Legacy automation/admin API fallback. Prefer the cookie login for the web UI.
VIBEGRID_ADMIN_TOKEN=""

# Frontend (Next.js)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
GO_BACKEND_URL="http://127.0.0.1:8081"
